[user]
    name = Rahul Sadarangani
    email = 6435446+rpsadarangani@users.noreply.github.com
    signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIC20T+SCrehiu7DUs7wlCLWXVqv1D/8PHmquH/1rWWc4

[credential]
    helper = osxkeychain

# ── 1Password Commit Signing (SSH) ───────────────────────────
[gpg]
    format = ssh

[gpg "ssh"]
    program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign

[commit]
    gpgsign = true

[tag]
    gpgsign = true

[core]
    pager = delta
    editor = code
    autocrlf = input
    excludesFile = ~/.gitignore_global
    sshCommand = ssh

[init]
    defaultBranch = main

[pull]
    rebase = true

[push]
    autoSetupRemote = true

[fetch]
    prune = true

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default

[rebase]
    autoStash = true

[delta]
    navigate = true
    side-by-side = true
    line-numbers = true
    syntax-theme = Dracula
    plus-style = "syntax #003800"
    minus-style = "syntax #3f0001"

[delta "interactive"]
    keep-plus-minus-markers = false

[alias]
    co = checkout
    br = branch
    ci = commit
    st = status
    last = log -1 HEAD
    unstage = reset HEAD --
    amend = commit --amend --no-edit
    branches = branch -a --sort=-committerdate
    tags = tag -l --sort=-v:refname
    stashes = stash list
    wip = !git add -A && git commit -m 'wip'
    undo = reset --soft HEAD~1
    contributors = shortlog --summary --numbered
    graph = log --graph --oneline --all --decorate
